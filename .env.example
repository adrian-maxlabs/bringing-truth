# Public Supabase (anon key — safe for NEXT_PUBLIC_*; never commit service role)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site URL for metadata, sitemap, and robots (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# External donation platform (GivingFuel, Pushpay, etc.)
NEXT_PUBLIC_DONATION_URL=

# Server-only: service role — NEVER expose to browser. Used by scripts/seed-admin.mjs
SUPABASE_SERVICE_ROLE_KEY=

# Seed admin (npm run seed:admin)
SEED_ADMIN_EMAIL=admin@bringingtruth.local
SEED_ADMIN_PASSWORD=ChangeThisPassword123!
